# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.
# Patterns without leading slash match anywhere (works for monorepo workspaces).

# ── Dependencies (root + per-workspace) ──────────────────────
node_modules
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ── Build output ─────────────────────────────────────────────
.next
out
dist
build
coverage

# ── TypeScript ───────────────────────────────────────────────
*.tsbuildinfo
next-env.d.ts

# ── Env files (NEVER commit secrets; .env.example IS committed) ──
.env
.env.local
.env*.local
.env.development
.env.production

# ── Vercel ───────────────────────────────────────────────────
.vercel

# ── Solana keypairs (base58 secret leaks here) ───────────────
fee-payer.json
treasury-*.json
*.keypair.json

# ── PWA generated artifacts (regenerated on build) ───────────
apps/web/public/sw.js
apps/web/public/sw.js.map
apps/web/public/swe-worker-*.js
apps/web/public/workbox-*.js

# ── Editor / OS junk ─────────────────────────────────────────
.idea/
.vscode/
*.swp
.DS_Store
Thumbs.db

# ── Debug logs ───────────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.pem

# ── Claude Code per-user settings ────────────────────────────
.claude/settings.local.json
.claude/scheduled_tasks.lock
