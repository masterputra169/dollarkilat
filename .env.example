# ─────────────────────────────────────────────────────────────
# dollarkilat — environment overview (monorepo)
#
# This file is a quick reference. Per-app templates live next to each app:
#
#   apps/web/.env.example  → cp to apps/web/.env.local  (frontend)
#   apps/api/.env.example  → cp to apps/api/.env.local  (backend)
#
# Both .env.local files are gitignored. Never commit them.
# ─────────────────────────────────────────────────────────────


# ═══ FRONTEND (apps/web/.env.local) ════════════════════════════
# See apps/web/.env.example for the full template with comments.

NEXT_PUBLIC_PRIVY_APP_ID=
NEXT_PUBLIC_PRIVY_SIGNER_ID=               # must match backend's PRIVY_AUTHORIZATION_KEY_ID
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_API_URL=http://localhost:8787  # Railway URL in prod
NEXT_PUBLIC_APP_URL=http://localhost:3000  # https://dollarkilat.xyz in prod


# ═══ BACKEND (apps/api/.env.local) ═════════════════════════════
# See apps/api/.env.example for the full template with comments.

PORT=8787
NODE_ENV=development
WEB_ORIGIN=http://localhost:3000           # comma-separated; prod: https://dollarkilat.xyz

PRIVY_APP_ID=
PRIVY_APP_SECRET=
PRIVY_AUTHORIZATION_KEY_ID=                # matches frontend NEXT_PUBLIC_PRIVY_SIGNER_ID
PRIVY_AUTHORIZATION_KEY=                   # PKCS8 P-256 private key, prefixed "wallet-auth:"

SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

HELIUS_RPC_URL=https://devnet.helius-rpc.com/?api-key=YOUR_HELIUS_KEY
SOLANA_NETWORK=devnet
USDC_MINT=4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU

FEE_PAYER_PRIVATE_KEY=                     # from `npm run fee-payer:generate`
TREASURY_USDC_ATA=                         # from `npm run treasury:setup`

COINGECKO_API_KEY=                         # optional, demo-tier key

PJP_PARTNER=flip                           # mock | flip
FLIP_BASE_URL=https://bigflip.id/big_sandbox_api/v2
PJP_API_KEY=                               # Flip "secret_key"
PJP_WEBHOOK_SECRET=                        # Flip "validation token"
