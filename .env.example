# ─────────────────────────────────────────────────────────────
# dollarkilat — environment variables (monorepo)
#
# Setup:
#   1. cp .env.example apps/web/.env.local
#   2. cp .env.example apps/api/.env.local
#   3. Isi value sebenarnya di MASING-MASING file.
#   4. Frontend hanya butuh NEXT_PUBLIC_* + Privy app id + Supabase anon.
#      Backend butuh secrets (Privy app secret, Supabase service role,
#      fee payer private key, PJP secrets).
#
# .env.local sudah di-gitignore. JANGAN commit.
# ─────────────────────────────────────────────────────────────


# ═══ FRONTEND (apps/web/.env.local) ════════════════════════════
# Privy client SDK
NEXT_PUBLIC_PRIVY_APP_ID=

# Supabase client (anon key — RLS enforced)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# API endpoint (where the Hono backend lives)
NEXT_PUBLIC_API_URL=http://localhost:8787

# App URL (untuk meta tags, deep links)
NEXT_PUBLIC_APP_URL=http://localhost:3000


# ═══ BACKEND (apps/api/.env.local) ═════════════════════════════
# Server runtime
PORT=8787
NODE_ENV=development
WEB_ORIGIN=http://localhost:3000   # comma-separated for multi-origin CORS

# Privy server SDK (delegated actions, token verify)
PRIVY_APP_ID=
PRIVY_APP_SECRET=

# Supabase service-role (bypass RLS for atomic ops)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Solana RPC (Helius free tier: https://dashboard.helius.dev)
HELIUS_RPC_URL=https://devnet.helius-rpc.com/?api-key=YOUR_KEY
SOLANA_NETWORK=devnet
# devnet:  4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU
# mainnet: EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v
USDC_MINT=4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU

# Fee payer wallet (devnet untuk demo)
# Generate: npm run fee-payer:generate
# Format: base58 dari 64-byte secret key
FEE_PAYER_PRIVATE_KEY=

# Treasury USDC ATA (Associated Token Account)
# Setup via scripts/setup-treasury.ts (Day 4)
TREASURY_USDC_ATA=

# Oracle (CoinGecko free tier tidak butuh key)
COINGECKO_API_KEY=

# PJP partner (sandbox/mock untuk hackathon)
PJP_PARTNER=mock                # mock | flip
PJP_API_KEY=
PJP_API_SECRET=
PJP_WEBHOOK_SECRET=
