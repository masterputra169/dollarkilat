{
  "name": "@dollarkilat/api",
  "version": "0.1.0",
  "private": true,
  "description": "dollarkilat — Hono backend API (Solana fee payer, Privy server, Supabase service-role, PJP partner).",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch --env-file=.env.local src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "tsx src/index.ts",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "fee-payer:generate": "tsx scripts/generate-fee-payer.ts",
    "treasury:setup": "tsx --env-file=.env.local scripts/setup-treasury.ts",
    "treasury:withdraw": "tsx --env-file=.env.local scripts/treasury-withdraw.ts",
    "qris:gen": "tsx scripts/generate-qris.ts",
    "seed:demo-merchants": "tsx --env-file=.env.local scripts/seed-demo-merchants.ts",
    "pjp:poll": "tsx --env-file=.env.local scripts/pjp-poll.ts"
  },
  "dependencies": {
    "@dollarkilat/shared": "*",
    "@hono/node-server": "^1.13.0",
    "@hono/zod-validator": "^0.4.0",
    "@privy-io/server-auth": "latest",
    "@solana-program/system": "latest",
    "@solana-program/token": "latest",
    "@solana/kit": "latest",
    "@solana/web3.js": "^1.95.0",
    "@supabase/supabase-js": "^2.45.0",
    "bignumber.js": "^9.1.2",
    "bs58": "^6.0.0",
    "hono": "^4.6.0",
    "tsx": "^4.19.0",
    "tweetnacl": "^1.0.3",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^20",
    "eslint": "^9",
    "typescript": "^5"
  }
}
