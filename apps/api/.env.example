# ─────────────────────────────────────────────────────────────
# dollarkilat — backend env (apps/api)
#
# Setup:
#   cp apps/api/.env.example apps/api/.env.local
#   Fill the values below.
#
# Contains SECRETS (Privy app secret, Supabase service-role, fee-payer
# private key, PJP API keys, Privy authorization private key). NEVER
# commit, NEVER paste publicly. .env.local is gitignored.
# ─────────────────────────────────────────────────────────────


# ── Server runtime ───────────────────────────────────────────────
PORT=8787
NODE_ENV=development

# CORS allowlist — comma-separated, no trailing slash, exact match.
# Local dev usually needs both localhost and your LAN IP for HP testing
# over Wi-Fi. Production: just the apex domain.
#   dev:  http://localhost:3000,http://192.168.1.x:3000
#   prod: https://dollarkilat.xyz
WEB_ORIGIN=http://localhost:3000


# ── Privy server SDK ─────────────────────────────────────────────
# verifyAuthToken (auth middleware), getUserById (sync flow),
# walletApi.solana.signTransaction (deposit-tax sweep).
PRIVY_APP_ID=
PRIVY_APP_SECRET=

# Authorization key — server-side credential that signs on the user's
# behalf via their session signer. The KEY_ID must match the public ID
# users register via /onboarding/consent (NEXT_PUBLIC_PRIVY_SIGNER_ID
# on the frontend).
#
# When KEY (the private part) is empty, deposit tax sweeps are skipped
# gracefully (logged, never fatal). Welcome bonus + payment fee work
# without it (those use the FEE_PAYER keypair below directly).
#
# From Privy Dashboard → Authorization keys → create one → reveal
# private key (PKCS8 P-256, prefixed "wallet-auth:").
PRIVY_AUTHORIZATION_KEY_ID=
PRIVY_AUTHORIZATION_KEY=


# ── Supabase service-role (bypass RLS for atomic ops) ───────────
# From Supabase Dashboard → Project Settings → API → service_role
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=


# ── Solana RPC ───────────────────────────────────────────────────
# Helius free tier (Jakarta-friendly latency): https://dashboard.helius.dev
HELIUS_RPC_URL=https://devnet.helius-rpc.com/?api-key=YOUR_HELIUS_KEY
SOLANA_NETWORK=devnet

# USDC mint address (chain-specific):
#   devnet:  4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU
#   mainnet: EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v
USDC_MINT=4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU


# ── Fee payer wallet (sponsors all SOL gas) ─────────────────────
# Generate a fresh keypair: npm run fee-payer:generate
# Output is the base58-encoded 64-byte Ed25519 secret. Paste it below.
# Fund the public key from a devnet faucet — 5 SOL covers a full demo.
# This wallet ALSO owns the treasury USDC ATA (single-keypair design
# for hackathon scope; production should split treasury and ops).
FEE_PAYER_PRIVATE_KEY=


# ── Treasury USDC ATA (deterministic from FEE_PAYER + USDC_MINT) ─
# After setting FEE_PAYER_PRIVATE_KEY above, run:
#   npm run treasury:setup
# It prints the derived ATA address. Paste it here.
TREASURY_USDC_ATA=


# ── Oracle (USDC↔IDR rate) ───────────────────────────────────────
# CoinGecko free tier doesn't require a key. With a demo-tier key you
# get higher limits + the x-cg-demo-api-key header is automatically
# attached. Leave empty for unauthenticated free-tier requests.
COINGECKO_API_KEY=


# ── PJP (Penyelenggara Jasa Pembayaran) partner ─────────────────
# mock = local simulation, no external calls. Use for unit tests + dev.
# flip = Flip Bisnis sandbox (real webhook flow).
PJP_PARTNER=flip

# Flip-specific. Production base URL: https://bigflip.id/api/v2
# Sandbox: https://bigflip.id/big_sandbox_api/v2 (default).
FLIP_BASE_URL=https://bigflip.id/big_sandbox_api/v2

# Per-partner credential mapping:
#   - flip: PJP_API_KEY        = Flip "secret_key" (Basic auth user)
#           PJP_WEBHOOK_SECRET = Flip "validation token" (must match
#                                the value in your Flip Dashboard)
PJP_API_KEY=
PJP_WEBHOOK_SECRET=
