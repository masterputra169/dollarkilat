# ─────────────────────────────────────────────────────────────
# dollarkilat — frontend env (apps/web)
#
# Setup:
#   cp apps/web/.env.example apps/web/.env.local
#   Fill the values below.
#
# All NEXT_PUBLIC_* vars are inlined into the client bundle at BUILD
# time — they're public, never put secrets here. Backend secrets live
# in apps/api/.env.example.
#
# .env.local is gitignored. Never commit it.
# ─────────────────────────────────────────────────────────────


# ── Privy embedded wallet (client SDK) ───────────────────────────
# From Privy Dashboard → Apps → your app → App ID
NEXT_PUBLIC_PRIVY_APP_ID=

# Privy authorization key ID — used by /onboarding/consent to register a
# session signer that the BACKEND will sign with on the user's behalf.
# Must match the key ID set as PRIVY_AUTHORIZATION_KEY_ID on the backend.
# From Privy Dashboard → Authorization keys → your key → "ID" (public).
# Required for One-Tap payments + deposit tax sweep.
NEXT_PUBLIC_PRIVY_SIGNER_ID=


# ── Supabase client (anon key — RLS enforced) ────────────────────
# From Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=


# ── Backend API endpoint ─────────────────────────────────────────
# Where the Hono backend lives (apps/api). Local dev uses :8787;
# production points at the Railway URL (no trailing slash).
NEXT_PUBLIC_API_URL=http://localhost:8787


# ── App canonical URL (meta tags, deep links, OG previews) ───────
# Local: http://localhost:3000
# Prod : https://dollarkilat.xyz (apex; www redirects via Vercel)
NEXT_PUBLIC_APP_URL=http://localhost:3000
